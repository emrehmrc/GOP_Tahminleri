# DIKKAT (2026): Mevcut Python transportu smtplib kullanici/parola girisi
# kullaniyor. Exchange Online Basic SMTP AUTH kaldirildigi icin Microsoft 365
# canli kurulumu OAuth/Graph'a tasinmadan bu ornegi gercek parola ile kullanmayin.
# Asagidaki alanlar kurumun izin verdigi bir SMTP relay varsa referanstir.
STLF_SMTP_HOST=smtp.office365.com
STLF_SMTP_PORT=587

# Bu, SMTP'ye gercekten giris yapabilen kullanici/shared mailbox olmalidir.
# talep.tahmin@mrc-tr.com bir dagitim listesi ise buraya yazilamaz.
STLF_SMTP_USER=<smtp-girisi-yapabilen-mrc-hesabi>
STLF_SMTP_PASS=<kurumun-izin-verdigi-kimlik-dogrulama-bilgisi>

# SMTP_USER hesabina bu dagitim listesi icin Microsoft 365 "Send As" yetkisi verilmeli.
STLF_FROM_ADDRESS=talep.tahmin@mrc-tr.com
STLF_SMTP_SEND_AS_CONFIRMED=false

# Test asamasinda yalnizca Emre. Canli alicilar daha sonra virgul ile eklenebilir.
STLF_CUSTOMER_TO=emre.hangul@mrc-tr.com
STLF_INTERNAL_TO=emre.hangul@mrc-tr.com,cagatay.bayrak@mrc-tr.com

STLF_CUSTOMER_SUBJECT=MRC-AYDEM Demo GÖP Tahmin Sonuçları

# Opsiyonel; bos birakilirsa proje kokune gore ../Emre/kartvizit.png bulunur.
# STLF_BUSINESS_CARD_PATH=C:\\...\\Emre\\kartvizit.png
